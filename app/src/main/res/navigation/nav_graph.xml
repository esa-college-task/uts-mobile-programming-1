<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.uts_mobile_programming_1.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboardFragment_to_achievementDetailFragment"
            app:destination="@id/achievementDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/gameListFragment"
        android:name="com.example.uts_mobile_programming_1.ui.gamelist.GameListFragment"
        android:label="Game List"
        tools:layout="@layout/fragment_game_list">
        <action
            android:id="@+id/action_gameListFragment_to_achievementDetailFragment"
            app:destination="@id/achievementDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/achievementDetailFragment"
        android:name="com.example.uts_mobile_programming_1.ui.detail.AchievementDetailFragment"
        android:label="Achievement Detail"
        tools:layout="@layout/fragment_achievement_detail">
        <argument
            android:name="game"
            app:argType="com.example.uts_mobile_programming_1.data.model.Game" />
    </fragment>
</navigation>
